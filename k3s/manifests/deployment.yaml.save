XapiVersion: apps/v1
kind: Deployment
metadata:
  name: aceest-deployment
spec:
  replicas: 2
  selector:
    matchLabels:
      app: aceest
  template:
    metadata:
      labels:
        app: aceest
    spec:
      containers:
      - name: aceest
        image: 095523581136.dkr.ecr.ap-south-2.amazonaws.com/aceest-app
        imagePullSecrets:
         -
        imagePullPolicy: Always
        ports:
        - containerPort: 5000
